<% layout("./layouts/boilerplate") %>
<body>
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">

                <h3 class="mb-4">Listing details</h3>

                <!-- Listing Card -->
                <div class="card border-0 mb-4">
                    <img src="<%=currListing.image.url %>"
                         class="card-img-top"
                         style="border-radius: 10px; height: 400px; object-fit: cover;"
                         alt="listing_image">
                    <div class="card-body px-0">
                        <h4 class="mb-2"><%=currListing.title%></h4>
                        <h5 class="text-primary mb-3">&#8377;<%=currListing.price.toLocaleString("en-IN")%>/night</h5>
                        <p class="mb-2"><%= currListing.description %></p>
                        <p class="text-muted"><%= currListing.location %>, <%= currListing.country %></p>

                        <!-- Edit/Delete Buttons -->
                        <% if(currUser && currListing.owner && currUser._id.equals(currListing.owner._id)) { %>
                        <div class="d-flex gap-2 mt-3">
                            <form action="/listing/edit/<%=currListing._id %>">
                                <button class="btn btn-primary">Edit</button>
                            </form>
                            <form method="post" action="/listing/delete/<%=currListing._id %>?_method=DELETE">
                                <button class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                        <% } %>
                    </div>
                </div>

                <hr class="my-4">

                <!-- Review Form -->
                <div class="mb-4">
                    <h5 class="mb-3">Leave a review</h5>
                    <form action="/listing/<%=currListing.id %>/review" method="Post" novalidate class="needs-validation">
                        <div class="mb-3">
                            <label for="rating" class="form-label">Rating</label>
                            <input type="range" min="1" max="5" name="review[rating]" class="form-range" id="rating">
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                            <div class="invalid-feedback">Please add some comments for reviews</div>
                        </div>
                        <button class="btn btn-primary">Submit</button>
                    </form>
                </div>

                <hr class="my-4">

                <!-- All Reviews -->
                <h4 class="mb-4">All Reviews</h4>
                <div class="row g-3">
                    <% for(review of currListing.reviews){ %>
                    <div class="col-md-6">
                        <div class="card review-card h-100">
                            <div class="card-body">
                                <h6 class="card-title mb-2">@<%= review.author.username%></h6>
                                <p class="card-text mb-2"><%=review.comment %></p>
                                <p class="card-text text-warning mb-3">
                                    <% for(let i = 0; i < review.rating; i++) { %>★<% } %>
                                    <% for(let i = review.rating; i < 5; i++) { %>☆<% } %>
                                </p>
                                <form method="POST" action="/listing/<%=currListing._id %>/review/<%=review._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</body>